# Copy this file to .env and update the values for your environment.

MCP_SERVER_NAME=Internal Applications MCP Server
MCP_SERVER_VERSION=1.1.0

# Registry file that defines the apps and endpoints exposed by this MCP server.
INTERNAL_APP_REGISTRY_FILE=config/internal-apps.php

# Default values used by config/internal-apps.php for the current Dashboard SOJ app.
INTERNAL_APP_BASE_URL=https://internal.api.co.id
INTERNAL_APP_API_BASE_PATH=/soj_api/Main
INTERNAL_APP_AUTH_HEADER=BCAi-ID
INTERNAL_APP_AUTH_SCHEME=
INTERNAL_APP_API_TOKEN=
INTERNAL_APP_USER_AGENT=internal-app-mcp-server/1.1.0

# Current Dashboard SOJ default.
SOJ_FETCH_GENERAL_DASHBOARD_DAYS_CHANGE=365

MCP_CONNECT_TIMEOUT_SECONDS=5
MCP_TIMEOUT_SECONDS=20
MCP_MAX_RETRIES=2
MCP_PAGINATION_LIMIT=50
MCP_VERIFY_TLS=false

MCP_SESSION_DIR=storage/sessions
MCP_SESSION_TTL=3600

MCP_LOG_LEVEL=warning
# Example: storage/logs/internal-app-mcp.log
MCP_LOG_FILE=
